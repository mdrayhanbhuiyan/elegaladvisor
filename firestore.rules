rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email.lower() == 'rayhanbhuiyan2021@gmail.com' ||
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    match /_admin_test/{docId} {
      allow read, write: if true;
    }

    function isValidPost(data) {
      return data.title is string && data.title.size() <= 500 &&
             data.slug is string && data.slug.size() <= 500 &&
             data.content is string && data.content.size() <= 500000 &&
             data.category is string &&
             data.status in ['draft', 'published', 'scheduled'];
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.token.email == 'rayhanbhuiyan2021@gmail.com';
    }

    match /posts/{postId} {
      // Public read for posts
      allow read: if true;
      allow create: if isAdmin() && isValidPost(request.resource.data);
      allow update: if (isAdmin() && isValidPost(request.resource.data)) || 
                       (
                         // Allow automated publication trigger if only status and updatedAt are changing
                         // and the transition is strictly from 'scheduled' to 'published'
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
                         request.resource.data.status == 'published' &&
                         resource.data.status == 'scheduled'
                       );
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && 
                      request.resource.data.authorId == request.auth.uid &&
                      request.resource.data.text is string &&
                      request.resource.data.text.size() <= 2000;
        allow update: if isSignedIn() && 
                      resource.data.authorId == request.auth.uid &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'updatedAt']);
        allow delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subscribers/{subscriberId} {
      allow create: if request.resource.data.email is string && 
                      request.resource.data.email.size() <= 256 &&
                      request.resource.data.email.matches('^[^@]+@[^@]+\\.[^@]+$');
      allow read, list, update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /unauthorized_attempts/{attemptId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    match /active_sessions/{sessionId} {
      allow read, list: if isAdmin();
      allow create, update: if true; 
    }

    match /analytics_events/{eventId} {
      allow create: if true; 
      allow read, list: if isAdmin();
    }

    match /analytics_stats/{statId} {
      allow read: if isAdmin();
      allow create, update: if true; 
    }

    // Default deny for all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
